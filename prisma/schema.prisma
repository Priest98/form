generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SurveyResponse {
  id                   String   @id @default(cuid())
  yearsInBusiness      String
  acceptsInterns       String
  findingMethods       String   // Will store stringified JSON array
  biggestChallenge     String
  struggledReliability String
  wouldUsePlatform     String
  valuableFeatures     String   // Will store stringified JSON array
  wouldPay             String
  improvement          String
  wantsEarlyAccess     Boolean
  
  // Optional early access fields
  name                 String?
  whatsapp             String?
  email                String?
  
  createdAt            DateTime @default(now())
}
